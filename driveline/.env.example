# Copy to .env and load before `npm start` if your shell supports it, or export manually:
# export DVLA_API_KEY="your-key-from-dvla-developer-portal"
DVLA_API_KEY=

# Enquiry forms use Web3Forms (browser). Set the access key in src/environments/environment.ts
# as web3formsAccessKey (local) or GitHub secret WEB3FORMS_ACCESS_KEY for CI — not in .env unless you wire it yourself.
